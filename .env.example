# =============================================================================
# Database (required)
# =============================================================================
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============================================================================
# Auth (required)
# =============================================================================
# Secret for session signing / impersonation — generate with: openssl rand -base64 32
AUTH_SECRET=

# =============================================================================
# Cron (required)
# =============================================================================
# Bearer token for authenticating cron job requests
CRON_SECRET=

# =============================================================================
# AI Generation — Google Vertex AI (required for Gutachten generation)
# =============================================================================
GOOGLE_VERTEX_PROJECT=                  # GCP project ID
GOOGLE_VERTEX_LOCATION=europe-west1    # Region
GOOGLE_SERVICE_ACCOUNT_EMAIL=           # z.B. name@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=                     # PEM private key (mit -----BEGIN/END PRIVATE KEY-----)

# =============================================================================
# Email (optional — disabled by default)
# =============================================================================
# EMAIL_DELIVERY_ENABLED=false    # set to "true" to send real emails
# EMAIL_FROM=GutachterKI <no-reply@gutachterki.de>
# SMTP_URL=smtp://user:pass@smtp.example.com:587

# =============================================================================
# Deployment (optional)
# =============================================================================
# BASE_URL=https://your-domain.com  # falls back to VERCEL_URL or localhost:3000

# =============================================================================
# Vercel (optional — auto-set by Vercel)
# =============================================================================
# VERCEL_URL=
# VERCEL_AUTOMATION_BYPASS_SECRET=

# =============================================================================
# Neon branch management (optional — required for CI e2e)
# =============================================================================
# NEON_PROJECT_ID=
# NEON_API_KEY=
# NEON_PARENT_BRANCH=production
# NEON_SCHEMA_ROOT_BRANCH=schema/root
# NEON_PROTECTED_BRANCHES=production
# NEON_DATABASE_NAME=
# NEON_ROLE_NAME=
# NEON_DEV_USERNAME=               # fallback: $USER

# =============================================================================
# Dev helpers (optional)
# =============================================================================
# NEXT_PUBLIC_AUTH_DEFAULT_EMAIL=   # pre-fill login form
# NEXT_PUBLIC_AUTH_DEFAULT_PASSWORD=
